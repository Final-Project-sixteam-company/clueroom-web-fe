VITE_API_BASE_URL=https://api.clueroom.xyz

# Google: OAuth 클라이언트 ID(브라우저 노출 공개값). 있으면 로그인 화면에 Google 버튼 노출.
VITE_GOOGLE_CLIENT_ID=236168911575-onncfs98p3bbeo94v8bitdqmm7g5u0dt.apps.googleusercontent.com

# Kakao: JavaScript 키(브라우저 노출 공개값, Kakao Developers > 앱 > 앱 키). 채우면
# 로그인 화면에 카카오 버튼이 자동 노출됨(비우면 숨김). 카카오 콘솔의 Web 플랫폼 사이트 도메인 +
# Redirect URI 에 배포 origin(예: https://www.clueroom.xyz)과 http://localhost:5173 을 등록할 것.
VITE_KAKAO_JAVASCRIPT_KEY=
VITE_ENABLE_DEV_LOGIN=false
VITE_ENABLE_QA_LOGIN=false
VITE_QA_LOGIN_EMAIL=
VITE_QA_LOGIN_NICKNAME=ClueRoom QA
